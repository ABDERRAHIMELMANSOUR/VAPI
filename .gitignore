# ─────────────────────────────────────────────────────────────
# VoxCRM monorepo — covers the backend (root) and vapi-frontend/
# Unanchored patterns apply at every depth.
# ─────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.*

# Environment files (example templates are committed on purpose)
.env
.env.*
!.env.example

# Backend build output
dist/
*.tsbuildinfo

# Frontend build output (Next.js)
.next/
out/
build/
next-env.d.ts
.vercel/

# Prisma local artifacts
prisma/*.db
prisma/*.db-journal

# Test coverage
coverage/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor & tooling state
.vscode/
.idea/
*.suo
*.swp

# OS garbage
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
ehthumbs.db

# Certificates / secrets that should never be committed
*.pem
*.key
