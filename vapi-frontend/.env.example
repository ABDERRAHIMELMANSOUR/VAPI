# Base URL of the VoxCRM backend API (server-side only — never exposed to the
# browser; all requests are proxied through Next.js route handlers).
#
# Resolution order at runtime:
#   1. BACKEND_API_URL              (this variable — preferred)
#   2. NEXT_PUBLIC_BACKEND_API_URL  (accepted alias)
#   3. In production builds: falls back to the live Railway backend
#      (https://vapi-production-49e8.up.railway.app) when neither is set
#   4. In development: http://localhost:8080
#
# Local development (backend running from ../):
#   BACKEND_API_URL=http://localhost:8080
#
# Production (Railway service variable):
#   BACKEND_API_URL=https://vapi-production-49e8.up.railway.app
BACKEND_API_URL=http://localhost:8080
