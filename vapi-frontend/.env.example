# Base URL of the VoxCRM backend API (server-side only — never exposed to the
# browser; all requests are proxied through Next.js route handlers).
#
# Local development (backend running from ../vapi):
#   BACKEND_API_URL=http://localhost:8080
#
# Production (your Railway deployment):
#   BACKEND_API_URL=https://<your-service>.up.railway.app
BACKEND_API_URL=http://localhost:8080
