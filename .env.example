# ─────────────────────────────────────────────────────────────
# Core
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
# Comma-separated list of allowed CORS origins, or * for all
CORS_ORIGIN=*

# JWT signing secret (min 16 chars). Used to sign/verify API tokens.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Public base URL of this server (used for Twilio callback/stream URLs).
# Optional on Railway: falls back to https://$RAILWAY_PUBLIC_DOMAIN automatically.
PUBLIC_BASE_URL=http://localhost:8080

# ─────────────────────────────────────────────────────────────
# Database (Prisma). `prisma generate` works without a live DB;
# a reachable DATABASE_URL is only needed for migrations/runtime.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/voxcrm?schema=public

# ─────────────────────────────────────────────────────────────
# Queue. If REDIS_URL is set, BullMQ is used. Otherwise the app
# falls back to an in-process async memory queue automatically.
# ─────────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# Voice pipeline providers. When a key is missing the matching
# provider degrades to a deterministic local stub so the server
# still runs end-to-end without external credentials.
# ─────────────────────────────────────────────────────────────
# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2

# ElevenLabs (Text-to-Speech)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2

# LLM provider: "openai" | "anthropic"
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ─────────────────────────────────────────────────────────────
# Email provider: "resend" | "smtp" | "console"
# `console` prints emails to stdout (default when unconfigured).
# ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@voxcrm.dev
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
